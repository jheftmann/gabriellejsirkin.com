{
  "name": "gabriellejsirkin-com",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "start": "concurrently \"node build.js --watch\" \"live-server --port=3000\" \"node scripts/auto-sync.js\"",
    "sync": "git fetch origin draft && git restore --source=origin/draft --worktree content/ && node build.js",
    "sync-draft": "bash scripts/sync-draft.sh"
  },
  "devDependencies": {
    "chokidar": "^3.6.0",
    "concurrently": "^8.2.2",
    "live-server": "^1.2.2",
    "marked": "^9.1.6"
  }
}
